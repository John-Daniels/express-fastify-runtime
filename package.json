{
  "name": "express-fastify-runtime",
  "version": "0.1.0",
  "description": "Run Express apps on Fastify safely, faster, without code changes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/unit/path.test.js test/unit/detect.test.js test/unit/assert.test.js test/integration/app.test.js",
    "test:unit": "node --test test/unit/path.test.js test/unit/detect.test.js test/unit/assert.test.js",
    "test:integration": "node --test test/integration/app.test.js",
    "benchmark": "node benchmarks/run.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^5.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "autocannon": "^7.14.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
