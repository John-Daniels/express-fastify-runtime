{
  "name": "express-fastify-runtime",
  "version": "0.1.0",
  "description": "Run Express apps on Fastify safely, faster, without code changes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/express-fastify-runtime/express-fastify-runtime.git"
  },
  "keywords": [
    "express",
    "fastify",
    "runtime",
    "compatibility",
    "middleware",
    "migration"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "changelog"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/unit/path.test.js test/unit/detect.test.js test/unit/assert.test.js test/unit/express-middleware.test.js test/integration/app.test.js",
    "test:unit": "node --test test/unit/path.test.js test/unit/detect.test.js test/unit/assert.test.js",
    "test:integration": "node --test test/integration/app.test.js",
    "benchmark": "node benchmarks/summary/report.js",
    "benchmark:servers": "node benchmarks/servers/run.js",
    "benchmark:routes": "node benchmarks/server-routes/run.js",
    "benchmark:json": "node benchmarks/json-db-test/run.js",
    "benchmark:lowdb": "node benchmarks/low-db-test/run.js",
    "benchmark:middleware": "node benchmarks/middleware-stack/run.js",
    "benchmark:auth": "node benchmarks/auth/run.js",
    "benchmark:crud": "node benchmarks/crud-todo/run.js",
    "benchmark:payloads": "node benchmarks/payloads/run.js",
    "benchmark:uploads": "node benchmarks/uploads/run.js",
    "benchmark:fast": "node benchmarks/fast-scenarios/run.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "accepts": "^1.3.8",
    "encodeurl": "^2.0.0",
    "express": "^5.0.0",
    "fastify": "^5.0.0",
    "range-parser": "^1.2.1",
    "type-is": "^2.0.1"
  },
  "devDependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "autocannon": "^7.14.0",
    "ejs": "^3.1.10",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
